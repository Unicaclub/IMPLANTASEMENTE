# Domain (used by nginx and CORS)
DOMAIN=seu-dominio.com.br

# Database
DB_USERNAME=copalite
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_DATABASE=copalite_db
DB_PORT=5432

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT — MUST be different from each other, minimum 32 chars
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARS_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_FROM_JWT_SECRET

# Credentials encryption — minimum 32 chars, required in production
CREDENTIALS_ENCRYPTION_KEY=CHANGE_ME_MINIMUM_32_CHARS_FOR_AES

# CORS (auto-derived from DOMAIN in docker-compose, but can override)
CORS_ORIGIN=https://seu-dominio.com.br

# Frontend (use /api/v1 when behind nginx proxy)
NEXT_PUBLIC_API_URL=/api/v1

# AI Agents (optional)
AGENT_AUTO_EXECUTE=false
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Certbot (for initial SSL setup)
CERTBOT_EMAIL=admin@seu-dominio.com.br
