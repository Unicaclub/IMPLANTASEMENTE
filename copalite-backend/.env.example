# ============================================
# COPALITE BACKEND - ENVIRONMENT CONFIGURATION
# ============================================

# Application
APP_PORT=3000
APP_ENV=development
APP_NAME=copalite-api

# Database - PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=copalite
DB_PASSWORD=copalite_dev_2024
DB_DATABASE=copalite_db
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_SSL=false

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# CORS
CORS_ORIGIN=http://localhost:3001

# ============================================
# LLM / AI Agent Execution
# ============================================

# Auto-execute agents via LLM when a pipeline step starts
# If false, agent runs are created but not executed automatically
AGENT_AUTO_EXECUTE=false

# Default LLM provider and model (used when agent.config is not set)
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514

# Provider API Keys (set only the ones you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
