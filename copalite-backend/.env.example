# ============================================
# COPALITE BACKEND — ENVIRONMENT CONFIGURATION
# ============================================

# ============================================
# APP
# ============================================
NODE_ENV=development
APP_PORT=3000

# ============================================
# DATABASE — PostgreSQL
# ============================================
# Obrigatorio
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=copalite
DB_PASSWORD=TROCAR_PARA_SENHA_REAL
DB_DATABASE=copalite_db
# Opcional
DB_LOGGING=false
DB_SSL=false

# ============================================
# AUTH — JWT
# ============================================
# Obrigatorio — minimo 32 caracteres cada
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# IMPORTANTE: JWT_SECRET e JWT_REFRESH_SECRET devem ser DIFERENTES
JWT_SECRET=GERAR_COM_COMANDO_ACIMA
JWT_REFRESH_SECRET=GERAR_COM_COMANDO_ACIMA_DIFERENTE_DO_ANTERIOR

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:3001

# ============================================
# LLM / AI Agent Execution
# ============================================
# Auto-execute agents via LLM quando um step de pipeline inicia
# Se false, agent runs sao criados mas nao executados automaticamente
AGENT_AUTO_EXECUTE=false

# Provider e modelo default (usado quando agent.config nao definido)
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514

# Chaves de API dos providers (setar apenas os que usar)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Ollama (LLM local)
OLLAMA_BASE_URL=http://localhost:11434
